+def degrade_spatial_resolution(
+    image,
+    valid_mask,
+    source_gsd,
+    target_gsd,
+):
+    """
+    Simula uma resolução espacial mais baixa e retorna a imagem
+    ao tamanho original exigido pela rede.
+
+    Etapas:
+        1. redução por média de área;
+        2. ampliação bilinear para o tamanho original.
+
+    Args:
+        image:
+            Tensor float32 no formato [C, H, W].
+
+        valid_mask:
+            Tensor booleano no formato [1, H, W].
+            True indica um pixel válido.
+
+        source_gsd:
+            Resolução espacial original em metros por pixel.
+
+        target_gsd:
+            Resolução espacial que será simulada.
+
+    Returns:
+        Tensor [C, H, W] com o mesmo tamanho da entrada.
+    """
+    if image.ndim != 3:
+        raise ValueError(
+            "A imagem deve possuir formato [C, H, W]. "
+            f"Formato recebido: {tuple(image.shape)}"
+        )
+
+    if valid_mask.ndim == 2:
+        valid_mask = valid_mask.unsqueeze(0)
+
+    if valid_mask.ndim != 3 or valid_mask.shape[0] != 1:
+        raise ValueError(
+            "A máscara deve possuir formato [1, H, W]. "
+            f"Formato recebido: {tuple(valid_mask.shape)}"
+        )
+
+    if image.shape[-2:] != valid_mask.shape[-2:]:
+        raise ValueError(
+            "A imagem e a máscara devem possuir as mesmas "
+            "dimensões espaciais."
+        )
+
+    if source_gsd <= 0 or target_gsd <= 0:
+        raise ValueError(
+            "source_gsd e target_gsd devem ser maiores que zero."
+        )
+
+    # A resolução original não sofre nenhuma alteração.
+    if target_gsd == source_gsd:
+        return image
+
+    if target_gsd < source_gsd:
+        raise ValueError(
+            "target_gsd não pode ser menor que source_gsd. "
+            "Esse procedimento simula apenas perda de resolução."
+        )
+
+    _, original_height, original_width = image.shape
+
+    reduced_height = max(
+        1,
+        round(original_height * source_gsd / target_gsd),
+    )
+
+    reduced_width = max(
+        1,
+        round(original_width * source_gsd / target_gsd),
+    )
+
+    # F.interpolate exige o formato [N, C, H, W].
+    image_batch = image.unsqueeze(0)
+
+    mask_batch = (
+        valid_mask
+        .to(dtype=image.dtype, device=image.device)
+        .unsqueeze(0)
+    )
+
+    epsilon = 1e-6
+
+    # ---------------------------------------------------------
+    # 1. Redução espacial por média de área
+    # ---------------------------------------------------------
+    #
+    # A imagem é multiplicada pela máscara para que pixels
+    # NoData não participem da média.
+    reduced_weighted_data = F.interpolate(
+        image_batch * mask_batch,
+        size=(reduced_height, reduced_width),
+        mode="area",
+    )
+
+    reduced_valid_fraction = F.interpolate(
+        mask_batch,
+        size=(reduced_height, reduced_width),
+        mode="area",
+    )
+
+    reduced_image = (
+        reduced_weighted_data
+        / reduced_valid_fraction.clamp_min(epsilon)
+    )
+
+    # ---------------------------------------------------------
+    # 2. Ampliação bilinear ao tamanho original
+    # ---------------------------------------------------------
+    #
+    # A fração válida também é interpolada para impedir que
+    # áreas NoData contaminem pixels vizinhos.
+    restored_weighted_data = F.interpolate(
+        reduced_image * reduced_valid_fraction,
+        size=(original_height, original_width),
+        mode="bilinear",
+        align_corners=False,
+    )
+
+    restored_valid_fraction = F.interpolate(
+        reduced_valid_fraction,
+        size=(original_height, original_width),
+        mode="bilinear",
+        align_corners=False,
+    )
+
+    restored_image = (
+        restored_weighted_data
+        / restored_valid_fraction.clamp_min(epsilon)
+    ).squeeze(0)
+
+    # Mantém como zero os pixels originalmente inválidos.
+    expanded_valid_mask = valid_mask.expand_as(restored_image)
+
+    restored_image = restored_image.masked_fill(
+        ~expanded_valid_mask,
+        0.0,
+    )
+
+    return restored_image
 
 
